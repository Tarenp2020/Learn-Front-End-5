<h1>Users</h1>

<div>
    <% users.forEach(user => { %>
        <div style="margin-bottom: 10px;">
            <h3><%= user.name %></h3>
            <p><%= user.email %></p>

            <a href="/users/<%= user.id %>">View Details</a>

            <form
                method="POST"
                action="/delete-user/<%= user.id %>"
            >
                <button type="submit">
                    Delete
                </button>
            </form>
        </div>
        <hr>
    <% }) %>
</div>

