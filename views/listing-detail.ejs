<% if (!listing) { %>
  <h1>Listing not found</h1>
<% } else { %>

<h1><%= listing.title %></h1>

<p><%= listing.description %></p>

<p><strong>Price:</strong> $<%= listing.price %></p>

<div id="imageContainer"></div>

<br>

<a href="/listings/<%= listing._id %>/edit" class="create-btn">
  Edit Listing
</a>
<br>
<button onclick="deleteListing('<%= listing._id %>')">
  Delete Listing
</button>

<br><br>

<a href="/listings" class="view-btn">Back to Listings</a>

<script>
async function loadImages() {
  try {
    const res = await fetch("http://localhost:5000/images/<%= listing._id %>");

    if (!res.ok) return;

    const images = await res.json();
    const container = document.getElementById("imageContainer");

    images.forEach(img => {
      const el = document.createElement("img");
      el.src = img.url;
      el.style.width = "200px";
      el.style.margin = "5px";
      container.appendChild(el);
    });

  } catch (err) {
    console.error("Image load failed:", err);
  }
}

loadImages();
</script>

<script>
async function deleteListing(id) {
  const res = await fetch(`http://localhost:5000/listings/${id}`, {
    method: "DELETE"
  });

  if (res.ok) {
    window.location.href = "/listings";
  } else {
    alert("Delete failed");
  }
}
</script>

<% } %>